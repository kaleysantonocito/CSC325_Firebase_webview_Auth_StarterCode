<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.csc325_firebase_webview_auth.view.SignInController"
            prefWidth="400" prefHeight="300">
    <children>
        <VBox alignment="CENTER" spacing="15" layoutX="50" layoutY="30" prefWidth="300" prefHeight="240">
            <Label text="Sign In" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <TextField fx:id="emailField" promptText="Email" />
            <PasswordField fx:id="passwordField" promptText="Password" />
            <Button text="Sign In" onAction="#handleSignIn" />
            <Label fx:id="errorLabel" textFill="red" />
        </VBox>
    </children>
</AnchorPane>

