<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.Color?>

<AnchorPane prefHeight="571.0" prefWidth="894.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.csc325_firebase_webview_auth.view.AccessFBView">

    <children>

        <!-- ================= MENU ================= -->
        <MenuBar layoutY="1.0" prefHeight="27.0" prefWidth="894.0" styleClass="top-menu">
            <menus>

                <Menu text="File">
                    <items>
                        <MenuItem text="Register" onAction="#openRegister"/>
                        <MenuItem text="Sign In" onAction="#openSignIn"/>
                        <MenuItem text="Close"/>
                    </items>
                </Menu>

                <Menu text="Edit">
                    <items>
                        <MenuItem text="Delete"/>
                    </items>
                </Menu>

                <Menu text="Help">
                    <items>
                        <MenuItem text="About"/>
                    </items>
                </Menu>

            </menus>
        </MenuBar>


        <!-- ================= MAIN CONTENT ================= -->
        <HBox layoutX="6.0" layoutY="28.0" prefHeight="535.0" prefWidth="880.0">

            <children>

                <!-- ================= LEFT SIDEBAR ================= -->
                <AnchorPane prefHeight="200.0" prefWidth="200.0" styleClass="left-sidebar">

                    <children>

                        <VBox layoutX="25.0" layoutY="30.0" alignment="CENTER" spacing="10" styleClass="avatar-box">

                            <ImageView fx:id="profileImageView"
                                       fitHeight="150.0"
                                       fitWidth="129.0"
                                       preserveRatio="true">

                                <effect>
                                    <InnerShadow>
                                        <color>
                                            <Color red="0.2065" green="0.168" blue="0.6"/>
                                        </color>
                                    </InnerShadow>
                                </effect>

                                <image>
                                    <Image url="@profile_empty.png"/>
                                </image>

                            </ImageView>

                        </VBox>

                    </children>

                </AnchorPane>


                <!-- ================= TABLE + OUTPUT ================= -->
                <VBox prefHeight="535.0" prefWidth="551.0">

                    <children>

                        <TextArea fx:id="outputField"
                                  prefHeight="184.0"
                                  prefWidth="514.0"/>

                        <TableView fx:id="userTable"
                                   prefHeight="351.0"
                                   prefWidth="514.0"
                                   styleClass="main-table">

                            <columns>

                                <TableColumn fx:id="nameColumn"
                                             text="Name"
                                             prefWidth="180"/>

                                <TableColumn fx:id="majorColumn"
                                             text="Major"
                                             prefWidth="180"/>

                                <TableColumn fx:id="ageColumn"
                                             text="Age"
                                             prefWidth="120"/>

                            </columns>

                        </TableView>

                    </children>

                </VBox>


                <!-- ================= RIGHT INPUT PANEL ================= -->
                <VBox prefHeight="535.0" prefWidth="241.0" spacing="12.0" styleClass="right-panel"
                      alignment="TOP_CENTER">

                    <children>
                        <TextField fx:id="nameField" promptText="Name" maxWidth="200"/>
                        <TextField fx:id="majorField" promptText="Major" maxWidth="200"/>
                        <TextField fx:id="ageField" promptText="Age" maxWidth="200"/>

                        <HBox spacing="12" alignment="CENTER">
                            <children>
                                <Button fx:id="readButton"
                                        text="Read"
                                        onAction="#readRecord"
                                        styleClass="action-btn"
                                        prefWidth="90"
                                        prefHeight="40"/>

                                <Button fx:id="writeButton"
                                        text="Write"
                                        onAction="#addRecord"
                                        styleClass="action-btn"
                                        prefWidth="90"
                                        prefHeight="40"/>
                            </children>
                        </HBox>

                        <Button fx:id="switchroot"
                                text="Switch"
                                onAction="#switchToSecondary"
                                styleClass="action-btn"
                                prefWidth="200"
                                prefHeight="40"/>
                    </children>

                    <padding>
                        <Insets top="16" bottom="16" left="16" right="16"/>
                    </padding>
                </VBox>

            </children>

        </HBox>

    </children>

</AnchorPane>

